# Адрес NameNode
CORE_CONF_fs_defaultFS=hdfs://namenode:9000

# Отключаем DNS-проверку hostname — в Docker она не работает
HDFS_CONF_dfs_namenode_datanode_registration_ip___hostname___check=false

# Размер блока: 16 МБ — оптимально для размера нашего датасета
HDFS_CONF_dfs_blocksize=16777216

# Отключаем safe mode на старте — не нужен для стенда
HDFS_CONF_dfs_namenode_safemode_threshold___pct=0